# Rezeptmeister – Umgebungsvariablen (Beispiel)
# Kopiere diese Datei nach .env.local und fülle die Werte aus.

# Datenbank
DB_PASSWORD=localdev
DATABASE_URL=postgresql://rezeptmeister:localdev@localhost:5432/rezeptmeister

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# FastAPI Backend
BACKEND_URL=http://localhost:8000

# Datei-Upload
UPLOAD_DIR=./uploads

# Verschlüsselung für API-Schlüssel (32-Byte-Hex, z.B. openssl rand -hex 32)
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-key-here-abcdef1234567890

# Produktion (S3-kompatibel)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=   # z.B. für Cloudflare R2 oder MinIO
