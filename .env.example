# Rezeptmeister – Umgebungsvariablen (Beispiel)
# Kopiere diese Datei nach .env.local und fülle die Werte aus.

# Datenbank
DB_PASSWORD=localdev
DATABASE_URL=postgresql://rezeptmeister:localdev@localhost:5432/rezeptmeister

# NextAuth
# Generieren: openssl rand -base64 48
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# FastAPI Backend
BACKEND_URL=http://localhost:8000

# Datei-Upload
UPLOAD_DIR=./uploads

# Verschlüsselung für API-Schlüssel (AES-256 – muss exakt 32 Byte Hex sein, d.h. 64 Hex-Zeichen)
# Generieren: openssl rand -hex 32
ENCRYPTION_KEY=

# Internes Shared Secret: Next.js → FastAPI
# Generieren: openssl rand -hex 32   (leer lassen in Entwicklung zum Deaktivieren)
INTERNAL_SECRET=

# ─── KI / BYOK ───────────────────────────────────────────────────────────────
# Gemini API-Schlüssel werden NICHT hier konfiguriert.
# Jeder Benutzer hinterlegt seinen eigenen Schlüssel unter /einstellungen.
# Der Schlüssel wird AES-256-verschlüsselt in der DB gespeichert.
# Unterstützte Anbieter: gemini (Standard), openai, claude
#
# Optionaler Test-Schlüssel für Live-E2E-Tests (nicht für Produktion):
# GEMINI_TEST_KEY=AIza...
#
# E2E-Test-Login (Playwright – niemals echte Produktionsdaten verwenden):
# TEST_ADMIN_EMAIL=test-admin@example.com
# TEST_ADMIN_PASSWORD=sicheres-test-passwort

# ─── FastAPI Backend ─────────────────────────────────────────────────────────
# Konfigurationswerte für den FastAPI KI-Service (backend/.env)
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# GEMINI_OCR_MODEL=gemini-3.1-pro-preview

# ─── Produktion (S3-kompatibel) ───────────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=   # z.B. für Cloudflare R2 oder MinIO
